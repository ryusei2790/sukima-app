// ============================================================
// Prisma スキーマ定義
// 役割: DBモデル（User・Task）の構造を定義する
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ユーザーモデル: メール/パスワード認証に使用
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcryptでハッシュ化して保存
  tasks     Task[]
  createdAt DateTime @default(now())
}

// タスクモデル: ユーザーが登録した隙間時間タスク
model Task {
  id        String   @id @default(cuid())
  label     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
